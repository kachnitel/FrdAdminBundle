{% import kachnitel_admin_theme as css %}

<div {{ attributes }}>
    <button
        type="button"
        class="{{ css.btn_danger() }} {{ css.btn_sm() }}"
        data-action="live#action"
        data-live-action-param="execute"
        {% if this.selectedIds|length == 0 %}disabled{% endif %}
        {% if this.selectedIds|length > 0 %}
            onclick="return confirm('Delete {{ this.selectedIds|length }} item(s)? This cannot be undone.')"
        {% endif %}
    >
        🗑 Delete Selected ({{ this.selectedIds|length }})
    </button>
</div>

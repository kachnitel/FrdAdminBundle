{#
 # RelationshipField - inline edit for ManyToOne / OneToOne.
 #
 # Edit mode renders a search input + result dropdown driven entirely by LiveComponent.
 # Selecting a result calls the `select` action; clearing calls `clear`.
 # No custom JS or UX Autocomplete dependency required.
 #}
{% import kachnitel_admin_theme as css %}

<div {{ attributes }}>
    {% if editMode and this.canEdit() %}
        <div>
            {# ── Currently selected pill ── #}
            {% if this.selectedLabel %}
                <div class="{{ css.flex_row() }} {{ css.gap_sm() }} {{ css.mb_1() }}">
                    <span>{{ this.selectedLabel }}</span>
                    <button
                        type="button"
                        class="{{ css.btn_link() }} {{ css.text_muted() }}"
                        data-action="live#action"
                        data-live-action-param="clear"
                        title="Clear selection"
                    >✕</button>
                </div>
            {% else %}
                <span class="{{ css.text_muted() }} {{ css.mb_1() }}">None selected</span>
            {% endif %}

            {# ── Search input ── #}
            <input
                type="search"
                class="{{ css.form_input_sm() }}"
                placeholder="Search…"
                data-model="debounce(300)|searchQuery"
                value="{{ searchQuery }}"
                autocomplete="off"
            >

            {# ── Results dropdown ── #}
            {% set results = this.searchResults %}
            {% if results is not empty %}
                <ul class="list-unstyled border rounded mt-1 mb-0" style="max-height:200px;overflow-y:auto">
                    {% for item in results %}
                        <li>
                            <button
                                type="button"
                                class="{{ css.btn_link() }} w-100 text-start px-2 py-1"
                                data-action="live#action"
                                data-live-action-param="select"
                                data-live-id-param="{{ item.id }}"
                            >{{ item.label }}</button>
                        </li>
                    {% endfor %}
                </ul>
            {% elseif searchQuery is not empty %}
                <p class="{{ css.text_muted() }} {{ css.mb_0() }} mt-1">No results.</p>
            {% endif %}

            {# ── Actions ── #}
            <div class="{{ css.flex_row() }} {{ css.gap_sm() }} mt-2">
                <button
                    type="button"
                    class="{{ css.btn_primary() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="save"
                >Save</button>
                <button
                    type="button"
                    class="{{ css.btn_secondary() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="cancelEdit"
                >Cancel</button>
            </div>
        </div>
    {% else %}
        {# ── Display mode ── #}
        <div class="{{ css.flex_row() }} {{ css.gap_sm() }}">
            <span>{{ this.renderValue()|raw }}</span>
            {% if this.canEdit() %}
                <button
                    type="button"
                    class="{{ css.btn_link() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="activateEditing"
                    title="Edit"
                >✎</button>
            {% endif %}
        </div>
    {% endif %}
</div>

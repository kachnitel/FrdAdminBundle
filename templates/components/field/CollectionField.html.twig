{#
 # CollectionField - inline edit for OneToMany / ManyToMany.
 #
 # Edit mode: search input drives getSearchResults() via LiveComponent re-render.
 # Selected entities shown as removable pills. No JS or UX Autocomplete required.
 #}
{% import kachnitel_admin_theme as css %}

<div {{ attributes }}>
    {% if editMode and this.canEdit() %}
        <div>
            {# ── Selected pills ── #}
            {% set selected = this.selectedItems %}
            {% if selected is not empty %}
                <div class="{{ css.flex_row() }} {{ css.gap_sm() }} flex-wrap mb-2">
                    {% for item in selected %}
                        <span class="badge bg-secondary {{ css.flex_row() }} {{ css.gap_sm() }}">
                            {{ item.label }}
                            <button
                                type="button"
                                class="{{ css.btn_close() }}"
                                style="font-size:.6rem"
                                data-action="live#action"
                                data-live-action-param="removeItem"
                                data-live-id-param="{{ item.id }}"
                                aria-label="Remove {{ item.label }}"
                            ></button>
                        </span>
                    {% endfor %}
                </div>
            {% else %}
                <p class="{{ css.text_muted() }} mb-2">None selected.</p>
            {% endif %}

            {# ── Search input ── #}
            <input
                type="search"
                class="{{ css.form_input_sm() }}"
                placeholder="Search to add…"
                data-model="debounce(300)|searchQuery"
                value="{{ searchQuery }}"
                autocomplete="off"
            >

            {# ── Results dropdown ── #}
            {% set results = this.searchResults %}
            {% if results is not empty %}
                <ul class="list-unstyled border rounded mt-1 mb-0" style="max-height:200px;overflow-y:auto">
                    {% for item in results %}
                        {# Dim already-selected items instead of hiding them #}
                        {% set alreadySelected = item.id in selectedIds %}
                        <li>
                            <button
                                type="button"
                                class="{{ css.btn_link() }} w-100 text-start px-2 py-1{% if alreadySelected %} {{ css.text_muted() }}{% endif %}"
                                {% if not alreadySelected %}
                                    data-action="live#action"
                                    data-live-action-param="addItem"
                                    data-live-id-param="{{ item.id }}"
                                {% else %}
                                    disabled
                                {% endif %}
                            >
                                {{ item.label }}
                                {% if alreadySelected %}<small>(added)</small>{% endif %}
                            </button>
                        </li>
                    {% endfor %}
                </ul>
            {% elseif searchQuery is not empty %}
                <p class="{{ css.text_muted() }} {{ css.mb_0() }} mt-1">No results.</p>
            {% endif %}

            {# ── Actions ── #}
            <div class="{{ css.flex_row() }} {{ css.gap_sm() }} mt-2">
                <button
                    type="button"
                    class="{{ css.btn_primary() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="save"
                >Save</button>
                <button
                    type="button"
                    class="{{ css.btn_secondary() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="cancelEdit"
                >Cancel</button>
            </div>
        </div>
    {% else %}
        {# ── Display mode ── #}
        <div class="{{ css.flex_row() }} {{ css.gap_sm() }}">
            <span>{{ this.renderValue() }}</span>
            {% if this.canEdit() %}
                <button
                    type="button"
                    class="{{ css.btn_link() }} {{ css.btn_sm() }}"
                    data-action="live#action"
                    data-live-action-param="activateEditing"
                    title="Edit"
                >✎</button>
            {% endif %}
        </div>
    {% endif %}
</div>

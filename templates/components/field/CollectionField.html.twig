{#
 # CollectionField - inline OneToMany / ManyToMany editor.
 #   this.editMode      - bool
 #   this.canEdit()     - bool
 #   this.selectedItems - array ({id, label})
 #   this.searchResults - array ({id, label})
 #   selectedIds        - array<int> (LiveProp)
 #   searchQuery        - string    (LiveProp)
 #}
{% import kachnitel_admin_theme as css %}

<div {{ attributes }}>
    {% if editMode and this.canEdit() %}
        {% set selected = this.selectedItems %}
        {% if selected is not empty %}
            <div class="{{ css.flex_row() }} {{ css.gap_sm() }} flex-wrap mb-2">
                {% for item in selected %}
                    <span class="badge bg-secondary {{ css.flex_row() }} {{ css.gap_sm() }}">
                        {{ item.label }}
                        <button type="button" class="{{ css.btn_close() }}" style="font-size:.6rem"
                            data-action="live#action" data-live-action-param="removeItem"
                            data-live-id-param="{{ item.id }}"
                            aria-label="Remove {{ item.label }}"></button>
                    </span>
                {% endfor %}
            </div>
        {% else %}
            <p class="{{ css.text_muted() }} mb-2">None selected.</p>
        {% endif %}

        <input type="search" class="{{ css.form_input_sm() }}" placeholder="Search to add…"
            data-model="debounce(300)|searchQuery" value="{{ searchQuery }}" autocomplete="off">

        {% set results = this.searchResults %}
        {% if results is not empty %}
            <ul class="list-unstyled border rounded mt-1 mb-0" style="max-height:200px;overflow-y:auto">
                {% for item in results %}
                    {% set alreadySelected = item.id in selectedIds %}
                    <li>
                        <button type="button"
                            class="{{ css.btn_link() }} w-100 text-start px-2 py-1{% if alreadySelected %} {{ css.text_muted() }}{% endif %}"
                            {% if not alreadySelected %}
                                data-action="live#action" data-live-action-param="addItem"
                                data-live-id-param="{{ item.id }}"
                            {% else %}
                                disabled
                            {% endif %}
                        >{{ item.label }}{% if alreadySelected %} <small>(added)</small>{% endif %}</button>
                    </li>
                {% endfor %}
            </ul>
        {% elseif searchQuery is not empty %}
            <p class="{{ css.text_muted() }} {{ css.mb_0() }} mt-1">No results.</p>
        {% endif %}

        <div class="{{ css.flex_row() }} {{ css.gap_sm() }} mt-2">
            <button type="button" class="{{ css.btn_primary() }} {{ css.btn_sm() }}"
                data-action="live#action" data-live-action-param="save">Save</button>
            <button type="button" class="{{ css.btn_secondary() }} {{ css.btn_sm() }}"
                data-action="live#action" data-live-action-param="cancelEdit">Cancel</button>
        </div>
    {% else %}
        <div class="{{ css.flex_row() }} {{ css.gap_sm() }}">
            {% include '@KachnitelAdmin/components/field/_display.html.twig' %}
            {% if this.canEdit() %}
                <button type="button" class="{{ css.btn_link() }} {{ css.btn_sm() }}"
                    data-action="live#action" data-live-action-param="activateEditing"
                    title="Edit">✎</button>
            {% endif %}
        </div>
    {% endif %}
</div>

{#
 # Row action buttons for a Doctrine entity row.
 #
 # When isRowEditing is true, only the ✕ exit button is shown — RowActions are suppressed to
 # prevent navigation away mid-edit. The exit button is NOT a RowAction; it belongs here
 # because it directly manipulates EntityList LiveProp editingRowId.
 #
 # When isRowEditing is false, the full RowAction loop runs. The default 'edit' action is
 # replaced by the InlineEditButton component (registered by InlineEditRowActionProvider),
 # which fires `editRow` on the parent EntityList LiveComponent.
 #
 # Variables:
 # @var object      entity          - The entity object
 # @var string      entityShortClass - Short class name for voter checks
 # @var string      entityClass      - Full entity class for RowAction registry lookup
 # @var bool        isRowEditing     - Whether this specific row is in inline-edit mode
 #}

{% import kachnitel_admin_theme as css %}

<td class="actions">
    {% if isRowEditing %}
        <button
            type="button"
            class="{{ css.btn_sm() }} {{ css.btn_secondary() }}"
            data-action="live#update"
            data-model="editingRowId"
            data-value=""
            title="Exit edit mode"
        >✕</button>
    {% else %}
        {% set actions = admin_visible_row_actions(entityClass, entity, entityShortClass, 'index') %}
        {% for action in actions %}
            {% include '@KachnitelAdmin/components/EntityList/_RowActionButton.html.twig' with {
                action: action,
                entity: entity,
                entityShortClass: entityShortClass
            } only %}
        {% endfor %}
    {% endif %}
</td>

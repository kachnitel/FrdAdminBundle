{#
 # Row actions with inline edit support.
 #
 # When canEditRow is true, shows ✏️ to enter row-edit mode (enabling per-field
 # edit overlays) and ✕ to exit it. Individual field components handle their
 # own save/cancel; there is no row-level flush.
 #
 # Variables (from include):
 # @var object entity
 # @var string entityShortClass
 # @var bool canEditRow
 #}

{% import kachnitel_admin_theme as css %}

<td class="actions">
    {% if isRowEditing %}
        {# ── Editing mode: exit button only ── #}
        <button
            type="button"
            class="{{ css.btn_sm() }} {{ css.btn_secondary() }}"
            {# data-action="live#action"
            data-live-action-param="exitRowEdit" #}
            data-action="live#update"
            data-model="editingRowId"
            data-value=""
            title="Exit edit mode"
        >
            ✕
        </button>
    {% else %}
        {# ── View mode ── #}
        {% if canEditRow %}
            <button
                type="button"
                class="{{ css.btn_sm() }} {{ css.btn_outline_primary() }}"
                data-action="live#action"
                data-live-action-param="editRow"
                data-live-id-param="{{ entity.id }}"
                title="Edit row"
            >
                ✏️
            </button>
        {% endif %}

        {% if admin_action_accessible(entityShortClass, 'show') %}
            <a href="{{ admin_object_path(entity, 'show') }}" class="{{ css.btn_outline_primary() }} {{ css.btn_sm() }}">
                👀
            </a>
        {% endif %}

        {% if admin_action_accessible(entityShortClass, 'edit') %}
            <a href="{{ admin_object_path(entity, 'edit') }}" class="{{ css.btn_outline_primary() }} {{ css.btn_sm() }}">
                🖊
            </a>
        {% endif %}
    {% endif %}
</td>

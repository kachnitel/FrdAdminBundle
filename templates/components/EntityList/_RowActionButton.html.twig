{#
 # Renders a single row action button.
 #
 # Rendering modes (checked in order):
 #   1. template       — custom Twig include
 #   2. liveComponent  — {{ component() }} with {entity} prop
 #   3. method         — form-based POST/DELETE
 #   4. default        — plain link
 #
 # Variables:
 # @var RowAction action          - The action configuration
 # @var object    entity          - The entity object
 # @var string    entityShortClass - Entity short class name
 #
 # Note: actions with listOnly=true are filtered by the caller (show/edit page templates),
 # not here. This partial renders whatever it receives.
 #}

{% import kachnitel_admin_theme as css %}

{% set entityId = entity.id is defined and entity.id is not null ? entity.id : null %}

{% if action.template %}
    {{ include(action.template, {
        action: action,
        entity: entity,
        entityShortClass: entityShortClass
    }) }}
{% elseif action.liveComponent %}
    {# Component actions receive {entity} as the standard prop contract.
       The component (RowActionComponentInterface) is responsible for its own rendering. #}
    {{ component(action.liveComponent, { entity: entity }) }}
{% elseif action.method %}
    {# Form-based action (POST/DELETE) #}
    <form method="post"
          action="{% if action.route %}{{ path(action.route, action.routeParams|merge(entityId is not null ? {id: entityId} : {})) }}{% elseif action.url %}{{ action.url }}{% else %}{{ admin_object_path(entity, action.name) }}{% endif %}"
          style="display: inline;"
          {% if action.confirmMessage %}onsubmit="return confirm('{{ action.confirmMessage|e('js') }}');"{% endif %}>
        <input type="hidden" name="_method" value="{{ action.method }}">
        <input type="hidden" name="_token" value="{{ csrf_token(action.name ~ '_' ~ (entityId ?? '')) }}">
        <button type="submit" class="{{ action.cssClass|default(css.btn_outline_primary() ~ ' ' ~ css.btn_sm()) }}"
                title="{{ action.label }}">
            {% if action.icon %}{{ action.icon }}{% else %}{{ action.label }}{% endif %}
        </button>
    </form>
{% else %}
    {# Link-based action #}
    <a href="{% if action.route %}{{ path(action.route, action.routeParams|merge(entityId is not null ? {id: entityId} : {})) }}{% elseif action.url %}{{ action.url }}{% else %}{{ admin_object_path(entity, action.name) }}{% endif %}"
       class="{{ action.cssClass|default(css.btn_outline_primary() ~ ' ' ~ css.btn_sm()) }}"
       title="{{ action.label }}"
       {% if action.openInNewTab %}target="_blank" rel="noopener"{% endif %}
       {% if action.confirmMessage %}onclick="return confirm('{{ action.confirmMessage|e('js') }}');"{% endif %}>
        {% if action.icon %}{{ action.icon }}{% else %}{{ action.label }}{% endif %}
    </a>
{% endif %}

{#
 # Batch actions bar — rendered inside EntityList when batch actions are enabled.
 #
 # The built-in DeleteButton is always present.
 # Custom batch actions (liveComponent or route/url) are rendered via
 # _BatchActionButton.html.twig for each action returned by admin_batch_actions().
 #
 # Variables:
 # @var array<int|string> selectedIds    - Currently selected entity IDs
 # @var string            entityClass    - Fully-qualified entity class name
 # @var string            entityShortClass - Short entity class name
 #}

{% import kachnitel_admin_theme as css %}

<div class="admin-batch-actions {{ css.flex_center() }} {{ css.gap_md() }}">
    {# Built-in batch delete — always present when batch actions bar is shown #}
    <twig:K:Admin:Action:Delete
        :selectedIds="selectedIds"
        :entityClass="entityClass"
        :entityShortClass="entityShortClass"
    />

    {# Custom batch actions from providers / #[AdminAction(actionType: BATCH|BOTH)] #}
    {% if entityClass is not empty %}
        {% for action in admin_batch_actions(entityClass) %}
            {% include '@KachnitelAdmin/components/EntityList/_BatchActionButton.html.twig' with {
                action: action,
                selectedIds: selectedIds,
                entityClass: entityClass,
                entityShortClass: entityShortClass
            } only %}
        {% endfor %}
    {% endif %}
</div>

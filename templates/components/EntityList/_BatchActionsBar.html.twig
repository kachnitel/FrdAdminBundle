{#
 # Partial template for batch actions bar.
 #
 # Renders:
 #   1. Default batch delete button (when entity has batch delete enabled)
 #   2. Custom batch action buttons from BatchActionRegistry (via admin_batch_actions())
 #
 # Variables:
 # @var int selectedCount - Number of selected items
 # @var string entityClass - Full entity class (for custom batch action lookup)
 # @var string entityShortClass - Short entity class (for route slug generation)
 # @var array selectedIds - Selected entity IDs (for form POST)
 #}

{% import kachnitel_admin_theme as css %}

<div class="admin-batch-actions {{ css.flex_center() }} {{ css.gap_md() }}">
    {# Default batch delete — always present when batch actions bar is shown #}
    <button
        type="button"
        class="{{ css.btn_danger() }} {{ css.btn_sm() }}"
        data-action="live#action"
        data-live-action-param="batchDelete"
        onclick="return confirm('Are you sure you want to delete the selected items?')"
    >
        Delete Selected ({{ selectedCount }})
    </button>

    {# Custom batch actions from providers / #[AdminAction] attributes #}
    {% if entityClass is not empty %}
        {% for action in admin_batch_actions(entityClass) %}
            {% include '@KachnitelAdmin/components/EntityList/_BatchActionButton.html.twig' %}
        {% endfor %}
    {% endif %}
</div>

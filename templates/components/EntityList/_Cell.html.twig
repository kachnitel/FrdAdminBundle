{% import kachnitel_admin_theme as css %}

{% if columnMeta and columnMeta.template %}
    {# Custom template specified in ColumnMetadata — highest priority #}
    {{ include(columnMeta.template, {
        entity: entity,
        item: entity,
        value: value,
        property: slot,
        cell: true
    }) }}

{% elseif not isDoctrineEntity %}
    {# Custom DataSource: template hierarchy for datasource columns #}
    {% set columnType = columnMeta ? columnMeta.type : 'string' %}
    {% set isCollection = columnType == 'collection' %}
    {{ include(admin_column_templates(component.dataSourceId, null, slot, columnType, isCollection), {
        entity: entity,
        value: value,
        property: slot,
        cell: true
    }, ignore_missing = true) }}

{% elseif rowEditing %}
    {# Inline edit mode for Doctrine entities.
        The Field LiveComponent renders both the display value and its own
        activateEditing trigger button internally — the trigger must live
        inside the component's root element so that live#action targets the
        correct component rather than EntityList.
        The wrapper span is provided solely for the Bootstrap optional
        hover-CSS upgrade path (see theme/bootstrap.html.twig). #}
    {% set fieldComponent = admin_field_component_name(entity, slot) %}
    {% if fieldComponent %}
        <span class="{{ css.field_editable_cell() }}">
            {{ component(fieldComponent, {
                entity: entity,
                property: slot,
                editMode: false
            }) }}
        </span>
    {% else %}
        {{ include(admin_entity_column_templates(entity, slot), {
            value: value,
            entity: entity,
            property: slot,
            cell: false
        }, ignore_missing = true) }}
    {% endif %}

{% else %}
    {# Read-only Doctrine entity cell #}
    {% set isCollection = admin_is_collection(entity, slot) %}
    {% set propertyType = admin_get_property_type(entity, slot) %}
    {{ include(admin_column_templates(null, component.entityClass, slot, propertyType, isCollection), {
        entity: entity,
        value: value,
        property: slot,
        cell: true
    }, ignore_missing = true) }}
{% endif %}

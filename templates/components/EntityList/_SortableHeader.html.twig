{#
 # Table header cell — sortable or plain depending on column metadata.
 #
 # Variables:
 # @var string      column        - Column name
 # @var string|null columnLabel   - Optional label override from DataSource column metadata
 # @var bool        sortable      - Whether this column supports sorting (default: true)
 # @var string      sortBy        - Currently sorted column
 # @var string      sortDirection - Current sort direction (ASC/DESC)
 # @var object      component     - Reference to parent component for constant access
 #}

{% import kachnitel_admin_theme as css %}

{% if sortable ?? true %}
<th>
    <button
        type="button"
        class="{{ css.btn_link() }}"
        data-action="live#action"
        data-live-action-param="sort"
        data-live-column-param="{{ column }}"
    >
        {{ columnLabel ?? column|humanize }}
        {% if sortBy == column %}
            <span class="sort-indicator">{{ sortDirection == constant('SORT_ASC', component) ? '▲' : '▼' }}</span>
        {% endif %}
    </button>
</th>
{% else %}
<th>{{ columnLabel ?? column|humanize }}</th>
{% endif %}

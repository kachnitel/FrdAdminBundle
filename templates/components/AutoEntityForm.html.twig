{#
 # Auto-generated form for entities without a manual FormType.
 #
 # New mode (entityId null):  renders plain HTML inputs via _new.html.twig.
 # Edit mode (entityId set):  renders K:Entity:Field:* LiveComponents via _edit.html.twig.
 #
 # Variables:
 # @var string       entityClass  - Fully-qualified entity class name
 # @var int|null     entityId     - Entity primary key (null for new)
 # @var bool         saveSuccess  - True after all fields have saved successfully
 # @var bool         hasErrors    - True if any field failed validation in last save
 #}

{% import kachnitel_admin_theme as css %}

<div data-admin-form {{ attributes }}>
    {% set fields = this.editableFields %}

    {% if saveSuccess %}
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
            <span>✓</span>
            <span>All changes saved successfully.</span>
        </div>
    {% endif %}

    {% if hasErrors %}
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
            <span>⚠</span>
            <span>Some fields could not be saved. Please review the errors below.</span>
        </div>
    {% endif %}

    {% if fields is empty %}
        <div class="{{ css.alert_warning() }}">
            No editable fields found. Add <code>#[Admin(enableInlineEdit: true)]</code>
            or <code>#[AdminColumn(editable: true)]</code> to your entity.
        </div>
    {% elseif this.isNew() %}
        {% include '@KachnitelAdmin/components/AutoEntityForm/_new.html.twig' with {
            fields: fields,
            formValues: formValues,
            formErrors: formErrors
        } %}
    {% else %}
        {% set entity = this.entity %}
        {% if entity is null %}
            <div class="{{ css.alert_warning() }}">Entity not found.</div>
        {% else %}
            {% include '@KachnitelAdmin/components/AutoEntityForm/_edit.html.twig' with {
                fields: fields,
                entity: entity
            } %}
        {% endif %}
    {% endif %}
</div>

{#
 # Generic new entity template.
 #
 # Variables:
 # @var string entityClass         - FQCN of the entity (e.g. App\Entity\Product)
 # @var string formTypeClass       - FQCN of the form type (e.g. App\Form\ProductFormType)
 # @var string formComponentName   - LiveComponent name to render (default: K:Admin:EntityForm)
 # @var array  breadcrumbs         - Breadcrumb navigation array
 #}
{% extends kachnitel_admin_base_layout ?: '@KachnitelAdmin/admin/base.html.twig' %}

{% block headerTitle %}New{% endblock %}

{% block headerButtons %}
  {{ include('@KachnitelAdmin/admin/_save_button.html.twig', {}, ignore_missing = true) }}
{% endblock %}

{% block content %}
  {{ component(formComponentName, {
      entityClass: entityClass,
      formTypeClass: formTypeClass
  }) }}
{% endblock %}

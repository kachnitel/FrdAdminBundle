{#
 # Generic entity edit template.
 #
 # Variables:
 # @var object entity              - The entity being edited
 # @var string entityClass         - FQCN of the entity (e.g. App\Entity\Product)
 # @var string formTypeClass       - FQCN of the form type (e.g. App\Form\ProductFormType)
 # @var string formComponentName   - LiveComponent name to render (default: K:Admin:EntityForm)
 # @var array  breadcrumbs         - Breadcrumb navigation array
 #}
{% extends kachnitel_admin_base_layout ?: '@KachnitelAdmin/admin/base.html.twig' %}

{% block headerTitle %}Edit{% endblock %}

{% block headerButtons %}
  {{ include('@KachnitelAdmin/admin/_delete_form.html.twig', {}, ignore_missing = true) }}
  {{ include('@KachnitelAdmin/admin/_save_button.html.twig', {}, ignore_missing = true) }}

  {# Render all entity actions except 'edit' (the current page).
     ignoreComponent: true forces liveComponent actions (e.g. inline-edit button) to
     render as plain navigation links — there is no parent EntityList on this page. #}
  {% set entityShortClass = entityClass|split('\\')|last %}
  {% for action in admin_visible_row_actions(entityClass, entity, entityShortClass) %}
    {% if action.name != 'edit' %}
      {{ include('@KachnitelAdmin/components/EntityList/_RowActionButton.html.twig', {
        action: action,
        entity: entity,
        entityShortClass: entityShortClass,
        ignoreComponent: true
      }) }}
    {% endif %}
  {% endfor %}
{% endblock %}

{% block content %}
  {{ component(formComponentName, {
      entityClass: entityClass,
      entityId: entity.id,
      formTypeClass: formTypeClass
  }) }}
{% endblock %}

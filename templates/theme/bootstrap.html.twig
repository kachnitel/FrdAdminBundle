{#
 # Bootstrap 5 CSS theme for KachnitelAdmin.
 #
 # Create your own theme by defining the same macros:
 #
 #   {# templates/admin/theme.html.twig #}
 #   {% macro btn_primary() %}btn btn-lg btn-primary{% endmacro %}
 #   {% macro form_input() %}form-control form-control-lg{% endmacro %}
 #   {# ... define all macros you want to override ... #}
 #
 # Then configure in kachnitel_admin.yaml:
 #   kachnitel_admin:
 #       theme: 'admin/theme.html.twig'
 #}

{# Buttons #}
{% macro btn_primary() %}btn btn-primary{% endmacro %}
{% macro btn_secondary() %}btn btn-secondary{% endmacro %}
{% macro btn_danger() %}btn btn-danger{% endmacro %}
{% macro btn_outline_primary() %}btn btn-outline-primary{% endmacro %}
{% macro btn_outline_secondary() %}btn btn-outline-secondary{% endmacro %}
{% macro btn_outline_info() %}btn btn-outline-info{% endmacro %}
{% macro btn_link() %}btn btn-link p-0 text-decoration-none{% endmacro %}
{% macro btn_close() %}btn-close{% endmacro %}
{% macro btn_sm() %}btn-sm{% endmacro %}

{# Forms #}
{% macro form_input() %}form-control{% endmacro %}
{% macro form_input_sm() %}form-control form-control-sm{% endmacro %}
{% macro form_select() %}form-select{% endmacro %}
{% macro form_select_sm() %}form-select form-select-sm{% endmacro %}
{% macro form_checkbox() %}form-check-input{% endmacro %}
{% macro form_label() %}form-label{% endmacro %}
{% macro form_label_sm() %}form-label mb-1{% endmacro %}

{# Compact form layout — used by @KachnitelAdmin/form/admin_compact.html.twig.
 #
 # form_row_compact     — Bootstrap grid row wrapping one label + one input column.
 # form_label_compact   — Applied via label_attr directly on the <label> element;
 #                        col-form-label aligns the label baseline with the adjacent input.
 # form_col_compact     — Input column wrapper div.
 # form_check_compact   — Inline wrapper for a checkbox and its descriptive label.
 # form_check_label     — Applied via label_attr on checkbox <label> elements.
 # form_section_heading — Full-width section title for compound / collection fields.
 #}
{% macro form_row_compact() %}row mb-2 align-items-baseline{% endmacro %}
{% macro form_label_compact() %}col-sm-3 col-form-label text-sm-end fw-normal{% endmacro %}
{% macro form_col_compact() %}col-sm-9{% endmacro %}
{% macro form_check_compact() %}form-check mb-0{% endmacro %}
{% macro form_check_label() %}form-check-label fw-normal{% endmacro %}
{% macro form_section_heading() %}fw-semibold small text-body-secondary d-block mt-3 mb-1 pb-1 border-bottom{% endmacro %}

{# Tables #}
{% macro table() %}table table-hover{% endmacro %}
{% macro table_simple() %}table{% endmacro %}
{% macro table_header() %}table-header{% endmacro %}

{# Pagination #}
{% macro pagination() %}pagination pagination-sm mb-0{% endmacro %}
{% macro page_item() %}page-item{% endmacro %}
{% macro page_item_disabled() %}page-item disabled{% endmacro %}
{% macro page_link() %}page-link{% endmacro %}

{# Layout #}
{% macro container() %}container-fluid{% endmacro %}
{% macro flex_row() %}d-flex{% endmacro %}
{% macro flex_center() %}d-flex align-items-center{% endmacro %}
{% macro flex_between() %}d-flex justify-content-between align-items-center{% endmacro %}
{% macro gap_sm() %}gap-1{% endmacro %}
{% macro gap_md() %}gap-2{% endmacro %}
{% macro gap_lg() %}gap-3{% endmacro %}
{% macro inline_block() %}d-inline-block w-auto{% endmacro %}
{% macro d_inline() %}d-inline{% endmacro %}
{% macro float_end() %}float-end{% endmacro %}
{% macro overflow_x_auto() %}overflow-auto{% endmacro %}

{# Cards #}
{% macro card() %}card h-100 shadow-sm{% endmacro %}
{% macro card_hover() %}card h-100 shadow-sm hover-shadow transition-all{% endmacro %}
{% macro card_info() %}card h-100 shadow-sm hover-shadow transition-all border-info{% endmacro %}
{% macro card_body() %}card-body text-center d-flex flex-column justify-content-center p-5{% endmacro %}
{% macro card_title() %}h5 card-title text-secondary mb-3{% endmacro %}

{# Alerts #}
{% macro alert_warning() %}alert alert-warning d-flex align-items-center{% endmacro %}

{# Dialog / Modal
   Used by the inline-add EntityTypeAddButton component to style a native
   <dialog> element with Bootstrap's existing modal classes — no custom CSS
   is required.

   dialog()        — applied to the <dialog> element itself. Combines
                      modal-dialog (max-width + auto horizontal margins) with
                      modal-content (border, background, border-radius, flex
                      column layout). border-0/p-0 strip the dialog element's
                      own UA-stylesheet border and padding so modal-content's
                      styling applies cleanly instead of stacking with it.
                      overflow-auto lets a tall inline form scroll within the
                      dialog rather than overflowing the viewport.
   dialog_header()  — header row: title + close button, bottom border.
   dialog_title()   — header text styling.
   dialog_body()    — content padding.

   Note: native <dialog> exposes a `::backdrop` pseudo-element for the overlay.
   Bootstrap does not provide a utility class for `::backdrop`, so this bundle
   uses the browser default backdrop. For custom styling, add a rule in your
   app stylesheet targeting `dialog.admin-inline-dialog::backdrop`.
   See MDN for details: https://developer.mozilla.org/docs/Web/API/HTMLDialogElement/backdrop
#}
{% macro dialog() %}position-fixed top-50 start-50 translate-middle modal-dialog modal-content border-0 p-0 overflow-auto{% endmacro %}
{% macro dialog_header() %}modal-header{% endmacro %}
{% macro dialog_title() %}modal-title fs-6{% endmacro %}
{% macro dialog_body() %}modal-body{% endmacro %}

{# Text #}
{% macro text_muted() %}text-muted{% endmacro %}
{% macro text_center() %}text-center{% endmacro %}
{% macro text_no_decoration() %}text-decoration-none{% endmacro %}

{# Spacing #}
{% macro mb_0() %}mb-0{% endmacro %}
{% macro mb_1() %}mb-1{% endmacro %}
{% macro mb_3() %}mb-3{% endmacro %}
{% macro mb_5() %}mb-5{% endmacro %}
{% macro mt_3() %}mt-3{% endmacro %}
{% macro me_2() %}me-2{% endmacro %}
{% macro py_4() %}py-4{% endmacro %}

{# Grid #}
{% macro row() %}row g-4{% endmacro %}
{% macro row_spaced() %}row g-4 mb-5{% endmacro %}
{% macro col_card() %}col-12 col-md-6 col-lg-4 col-xl-3{% endmacro %}
{% macro col_full() %}col-12{% endmacro %}

{# Heading #}
{% macro h4() %}h4 mb-3{% endmacro %}

{# Inline Edit
   field_editable_cell — wrapper around a cell's display value.
   field_edit_trigger  — the ✏️ button that activates per-field editing.

   Default (no extra CSS required):
     The trigger is always visible but visually recessive — a muted, small link
     button that does not distract until the row is in edit mode.

   Optional upgrade (hover-reveal, matches Tailwind behaviour):
     Add these 2 rules to your project's CSS (e.g. app.css) to hide the trigger
     until the cell is hovered or keyboard-focused:

         .field-edit-trigger { opacity: 0; transition: opacity .15s; }
         .field-editable-cell:hover .field-edit-trigger,
         .field-editable-cell:focus-within .field-edit-trigger { opacity: 1; }
#}
{% macro field_editable_cell() %}d-inline-flex align-items-center gap-1 field-editable-cell{% endmacro %}
{% macro field_edit_trigger() %}btn btn-link p-0 text-body-tertiary lh-1 field-edit-trigger{% endmacro %}

{# Archive / Soft-delete
   row_archived() — applied to <tr> elements for archived/soft-deleted records
   when showArchived=true. Uses Bootstrap's table-secondary contextual class for
   a muted grey background, combined with text-muted and fst-italic so archived
   rows are visually recessive without hiding information.

   Override in your own theme or via CSS if you prefer a different treatment, e.g.:

       tr.admin-row-archived { border-left: 3px solid var(--bs-warning); }
#}
{% macro row_archived() %}table-secondary text-muted fst-italic opacity-50{% endmacro %}

{# Collection inline display #}
{% macro collection_details() %}admin-collection-details{% endmacro %}
{% macro collection_summary() %}admin-collection-summary d-flex align-items-center gap-1{% endmacro %}
{% macro collection_view_all() %}ms-auto{% endmacro %}
{% macro collection_inline() %}admin-collection-inline{% endmacro %}
{% macro collection_inline_header() %}d-flex align-items-center gap-1{% endmacro %}
{% macro collection_list() %}list-unstyled mb-0 mt-1 ps-2 admin-collection-list{% endmacro %}
{% macro collection_list_item() %}small{% endmacro %}

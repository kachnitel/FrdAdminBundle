{#
 # Tailwind CSS theme for KachnitelAdmin.
 #
 # Configure in kachnitel_admin.yaml:
 #   kachnitel_admin:
 #       theme: '@KachnitelAdmin/theme/tailwind.html.twig'
 #}

{# Buttons #}
{% macro btn_primary() %}inline-flex items-center px-4 py-2 bg-blue-600 border border-transparent rounded-md font-semibold text-xs text-white uppercase tracking-widest hover:bg-blue-700 focus:bg-blue-700 active:bg-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_secondary() %}inline-flex items-center px-4 py-2 bg-white border border-gray-300 rounded-md font-semibold text-xs text-gray-700 uppercase tracking-widest shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_danger() %}inline-flex items-center px-4 py-2 bg-red-600 border border-transparent rounded-md font-semibold text-xs text-white uppercase tracking-widest hover:bg-red-700 focus:bg-red-700 active:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_outline_primary() %}inline-flex items-center px-4 py-2 bg-transparent border border-blue-600 rounded-md font-semibold text-xs text-blue-600 uppercase tracking-widest hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_outline_secondary() %}inline-flex items-center px-4 py-2 bg-transparent border border-gray-300 rounded-md font-semibold text-xs text-gray-700 uppercase tracking-widest hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_outline_info() %}inline-flex items-center px-4 py-2 bg-transparent border border-cyan-500 rounded-md font-semibold text-xs text-cyan-600 uppercase tracking-widest hover:bg-cyan-50 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 transition ease-in-out duration-150 disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none{% endmacro %}
{% macro btn_link() %}text-blue-600 hover:text-blue-800 hover:underline focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none disabled:no-underline{% endmacro %}
{% macro btn_close() %}text-gray-400 hover:text-gray-600 focus:outline-none{% endmacro %}
{% macro btn_sm() %}text-xs px-2 py-1{% endmacro %}

{# Forms #}
{% macro form_input() %}block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 aria-invalid:border-red-500 aria-invalid:ring-1 aria-invalid:ring-red-500 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:opacity-60{% endmacro %}
{% macro form_input_sm() %}block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1 aria-invalid:border-red-500 aria-invalid:ring-1 aria-invalid:ring-red-500 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:opacity-60{% endmacro %}
{% macro form_select() %}block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 aria-invalid:border-red-500 aria-invalid:ring-1 aria-invalid:ring-red-500 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:opacity-60{% endmacro %}
{% macro form_select_sm() %}block rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1 aria-invalid:border-red-500 aria-invalid:ring-1 aria-invalid:ring-red-500 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:opacity-60{% endmacro %}
{% macro form_checkbox() %}h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 disabled:cursor-not-allowed disabled:opacity-60{% endmacro %}
{% macro form_label() %}block text-sm font-medium text-gray-700{% endmacro %}
{% macro form_label_sm() %}block text-xs font-medium text-gray-600 mb-1{% endmacro %}

{# Compact form layout — used by @KachnitelAdmin/form/admin_compact.html.twig.
 #
 # form_row_compact     — CSS grid row (12 cols) wrapping one label + one input column.
 # form_label_compact   — Applied via label_attr directly on the <label> element.
 # form_col_compact     — Input column wrapper div (9 of 12 columns).
 # form_check_compact   — Inline wrapper for a checkbox and its descriptive label.
 # form_check_label     — Applied via label_attr on checkbox <label> elements.
 # form_section_heading — Full-width section title for compound / collection fields.
 #}
{% macro form_row_compact() %}grid grid-cols-12 gap-x-3 mb-2.5 items-baseline{% endmacro %}
{% macro form_label_compact() %}col-span-3 text-sm text-right text-gray-500 font-normal pt-1.5{% endmacro %}
{% macro form_col_compact() %}col-span-9{% endmacro %}
{% macro form_check_compact() %}flex items-center gap-2{% endmacro %}
{% macro form_check_label() %}text-sm text-gray-700{% endmacro %}
{% macro form_section_heading() %}text-xs font-semibold uppercase tracking-wide text-gray-500 mt-4 mb-1 pb-1 border-b border-gray-200 block{% endmacro %}

{# Tables #}
{% macro table() %}min-w-full divide-y divide-gray-200{% endmacro %}
{% macro table_simple() %}min-w-full{% endmacro %}
{% macro table_header() %}bg-gray-50{% endmacro %}

{# Pagination #}
{% macro pagination() %}inline-flex -space-x-px rounded-md shadow-sm{% endmacro %}
{% macro page_item() %}{% endmacro %}
{% macro page_item_disabled() %}opacity-50 cursor-not-allowed{% endmacro %}
{% macro page_link() %}relative inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500{% endmacro %}

{# Layout #}
{% macro container() %}container mx-auto px-4{% endmacro %}
{% macro flex_row() %}flex{% endmacro %}
{% macro flex_center() %}flex items-center{% endmacro %}
{% macro flex_between() %}flex justify-between items-center{% endmacro %}
{% macro gap_sm() %}gap-1{% endmacro %}
{% macro gap_md() %}gap-2{% endmacro %}
{% macro gap_lg() %}gap-3{% endmacro %}
{% macro inline_block() %}inline-block{% endmacro %}
{% macro d_inline() %}inline{% endmacro %}
{% macro float_end() %}float-right{% endmacro %}
{% macro overflow_x_auto() %}overflow-x-auto{% endmacro %}

{# Cards #}
{% macro card() %}bg-white rounded-lg shadow{% endmacro %}
{% macro card_hover() %}bg-white rounded-lg shadow hover:shadow-lg transition-shadow duration-200{% endmacro %}
{% macro card_info() %}bg-white rounded-lg shadow hover:shadow-lg transition-shadow duration-200 border-l-4 border-cyan-500{% endmacro %}
{% macro card_body() %}p-6 text-center flex flex-col justify-center{% endmacro %}
{% macro card_title() %}text-lg font-medium text-gray-600 mb-3{% endmacro %}

{# Alerts #}
{% macro alert_warning() %}flex items-center p-4 bg-yellow-50 border-l-4 border-yellow-400 text-yellow-700{% endmacro %}

{# Dialog / Modal
   See bootstrap.html.twig for the full explanation of how these macros style
   the native <dialog> element used by the EntityTypeAddButton inline-add
   component — no custom CSS is required.

   dialog()        — applied to the <dialog> element itself. max-w-xl caps the
                      width at a sensible size for a simple entity form;
                      max-h-screen + overflow-auto let a tall form scroll
                      within the dialog instead of overflowing the viewport.
                      border-0/p-0 strip the dialog element's own UA-stylesheet
                      border and padding.
   dialog_header()  — header row: title + close button, bottom border.
   dialog_title()   — header text styling.
   dialog_body()    — content padding.

   Note: native <dialog> exposes a `::backdrop` pseudo-element for the overlay.
   Tailwind's core utility classes have no non-arbitrary way to target
   ::backdrop. The browser's default backdrop dimming is used as-is. To darken
   it, add to your own project CSS (e.g. app.css):

       .admin-inline-dialog::backdrop { background: rgb(0 0 0 / .45); }

   then apply that extra class via a template override of
   EntityTypeAddButton.html.twig.
#}
{% macro dialog() %}w-full max-w-xl max-h-screen overflow-auto rounded-lg shadow-2xl border-0 p-0 bg-white{% endmacro %}
{% macro dialog_header() %}flex items-center justify-between px-5 py-3.5 border-b border-gray-200{% endmacro %}
{% macro dialog_title() %}font-semibold text-base{% endmacro %}
{% macro dialog_body() %}p-5{% endmacro %}

{# Text #}
{% macro text_muted() %}text-gray-500{% endmacro %}
{% macro text_center() %}text-center{% endmacro %}
{% macro text_no_decoration() %}no-underline{% endmacro %}

{# Spacing #}
{% macro mb_0() %}mb-0{% endmacro %}
{% macro mb_1() %}mb-1{% endmacro %}
{% macro mb_3() %}mb-3{% endmacro %}
{% macro mb_5() %}mb-8{% endmacro %}
{% macro mt_3() %}mt-3{% endmacro %}
{% macro me_2() %}mr-2{% endmacro %}
{% macro py_4() %}py-4{% endmacro %}

{# Grid #}
{% macro row() %}grid grid-cols-1 gap-4{% endmacro %}
{% macro row_spaced() %}grid grid-cols-1 gap-4 mb-8{% endmacro %}
{% macro col_card() %}md:col-span-1{% endmacro %}
{% macro col_full() %}col-span-full{% endmacro %}

{# Heading #}
{% macro h4() %}text-xl font-semibold mb-3{% endmacro %}

{# Inline Edit
   field_editable_cell — wrapper around a cell's display value.
     The `group` class enables group-hover targeting for the child trigger.
   field_edit_trigger  — the ✏️ button revealed on hover.
     Stays invisible until the parent cell is hovered or focused-within.
     No extra CSS required — all behaviour is expressed via Tailwind utilities.
#}
{% macro field_editable_cell() %}group relative inline-flex items-center gap-1{% endmacro %}
{% macro field_edit_trigger() %}opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity duration-150 text-gray-400 hover:text-gray-600 p-0.5 rounded leading-none{% endmacro %}

{# Archive / Soft-delete
   row_archived() — applied to <tr> elements for archived/soft-deleted records
   when showArchived=true. Uses standard Tailwind utility classes that are
   scanned from this template file, so no safelist entry is required.
#}
{% macro row_archived() %}opacity-60 italic text-gray-400{% endmacro %}

{# Collection inline display #}
{% macro collection_details() %}admin-collection-details{% endmacro %}
{% macro collection_summary() %}admin-collection-summary flex items-center gap-1 cursor-pointer list-none{% endmacro %}
{% macro collection_view_all() %}ml-auto{% endmacro %}
{% macro collection_inline() %}admin-collection-inline{% endmacro %}
{% macro collection_inline_header() %}flex items-center gap-1{% endmacro %}
{% macro collection_list() %}list-none pl-2 mt-1 mb-0 space-y-0.5 admin-collection-list{% endmacro %}
{% macro collection_list_item() %}text-sm{% endmacro %}

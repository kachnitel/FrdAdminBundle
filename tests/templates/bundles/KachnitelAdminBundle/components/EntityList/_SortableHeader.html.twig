{#
 # Table header cell — sortable or plain (test override, no CSS macros).
 #
 # @var string      column
 # @var string|null columnLabel
 # @var bool        sortable
 # @var string      sortBy
 # @var string      sortDirection
 # @var object      component
 #}

{% if sortable ?? true %}
<th>
    <button
        type="button"
        class="btn btn-link p-0 text-decoration-none"
        data-action="live#action"
        data-live-action-param="sort"
        data-live-column-param="{{ column }}"
    >
        {{ columnLabel ?? column|humanize }}
        {% if sortBy == column %}
            <span class="sort-indicator">{{ sortDirection == constant('SORT_ASC', component) ? '▲' : '▼' }}</span>
        {% endif %}
    </button>
</th>
{% else %}
<th>{{ columnLabel ?? column|humanize }}</th>
{% endif %}

{
    "name": "@kachnitel/admin-bundle",
    "description": "Batch select controller for Kachnitel Admin Bundle",
    "license": "MIT",
    "version": "0.1.0",
    "keywords": [
        "symfony-ux",
        "stimulus",
        "admin"
    ],
    "homepage": "https://github.com/kachnitel/FrdAdminBundle",
    "type": "module",
    "files": [
        "controllers"
    ],
    "symfony": {
        "controllers": {
            "batch-select": {
                "main": "controllers/batch-select_controller.js",
                "name": "batch-select",
                "webpackMode": "eager",
                "fetch": "eager",
                "enabled": true
            },
            "admin-inline-add": {
                "main": "controllers/admin-inline-add_controller.js",
                "name": "admin-inline-add",
                "webpackMode": "eager",
                "fetch": "eager",
                "enabled": true
            }
        },
        "importmap": {
            "@hotwired/stimulus": "^3.0.0",
            "@kachnitel/admin-bundle/batch-select_controller.js": "path:%PACKAGE%/controllers/batch-select_controller.js",
            "@kachnitel/admin-bundle/admin-inline-add_controller.js": "path:%PACKAGE%/controllers/admin-inline-add_controller.js"
        }
    },
    "peerDependencies": {
        "@hotwired/stimulus": "^3.0.0"
    },
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@hotwired/stimulus": "^3.2.2",
        "@testing-library/dom": "^10.4.1",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.9"
    }
}
